# Скопируйте в .env на сервере: cp .env.example .env
# Сгенерировать SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=your-secret-key-here-min-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-server-ip,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://your-server-ip:8000
DJANGO_USE_HTTPS=false
